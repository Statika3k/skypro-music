{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@components/*": ["./src/components/*"],
      "@bar/*": ["./src/components/Bar/*"],
      "@navigation/*": ["./src/components/Navigation/*"],
      "@sidebar/*": ["./src/components/Sidebar/*"],
      "@centerblock/*": ["./src/components/Centerblock/*"],
      "@track/*": ["./src/components/Track/*"],
      "@filter/*": ["./src/components/Filter/*"],
      "@filterItem/*": ["./src/components/FilterItem/*"],
      "@search/*": ["./src/components/Search/*"],
      "@tracklist/*": ["./src/components/Tracklist/*"],
      "@listheader/*": ["./src/components/Listheader/*"],
      "@loading/*": ["./src/components/Loading/*"],
      "@progressBar/*": ["./src/components/ProgressBar/*"],
      
      "@store/*": ["./src/store/*"],
      "@utils/*": ["./src/utils/*"],
      "@sharedTypes/*": ["./src/sharedTypes/*"],
      "@data/*": ["./src/data/*"],
      
      "@auth/*": ["./src/app/auth/*"],
      "@signin/*": ["./src/app/auth/signin/*"],
      "@signup/*": ["./src/app/auth/signup/*"],

      "@/*": ["./src/*"],      
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
